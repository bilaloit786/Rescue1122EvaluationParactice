# Database - use the deployment database URL, never commit the real value.
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST/DATABASE?ssl=require

# JWT - generate with: openssl rand -hex 32
SECRET_KEY=replace-with-a-generated-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email - get from resend.com
RESEND_API_KEY=replace-with-resend-api-key
EMAIL_FROM=noreply@rescue1122.gov.pk

# App
APP_NAME=Rescue 1122 Evaluation System
FRONTEND_URL=https://rescue1122.vercel.app
ENVIRONMENT=production

# Security
ALLOWED_HOSTS=rescue1122-api.onrender.com,*.onrender.com
BCRYPT_ROUNDS=12
